# Database
DATABASE_URL=postgresql+asyncpg://onboard_user:onboard_pass@localhost:5432/onboarding_db

# Redis
REDIS_URL=redis://localhost:6379/1

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hr@company.com
SMTP_PASS=your_app_password

# Slack (Bot Token from https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_DEFAULT_CHANNEL=#general

# Jira
JIRA_URL=https://yourcompany.atlassian.net
JIRA_USER=admin@yourcompany.com
JIRA_API_TOKEN=your_jira_api_token

# HR Portal automation
HR_PORTAL_URL=https://hr.company.com
HR_PORTAL_USER=hr_admin@company.com
HR_PORTAL_PASS=your_portal_password

# File output directories
DOCS_OUTPUT_DIR=/data/documents
SCREENSHOTS_DIR=/data/screenshots

# Logging
LOG_LEVEL=INFO

# Company branding
COMPANY_NAME=Acme Corporation
WELCOME_EMAIL_FROM=hr@company.com
